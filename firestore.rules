rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // True when the signed-in user belongs to the given company
    function isCompanyUser(companyId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/company_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/company_users/$(request.auth.uid)).data.company_id == companyId;
    }

    // True when the signed-in user is any company user (has a company_users doc)
    function isAnyCompanyUser() {
      return isAuth() &&
        exists(/databases/$(database)/documents/company_users/$(request.auth.uid));
    }

    // ── companies ────────────────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read:   if true; // public — company profile is shown on job previews
      allow create: if isAuth();
      allow update: if isCompanyUser(companyId);
    }

    // ── company_users ────────────────────────────────────────────────────────
    match /company_users/{userId} {
      allow read:  if isAuth();
      allow write: if isOwner(userId);
    }

    // ── company_invitations ──────────────────────────────────────────────────
    match /company_invitations/{invId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── candidates ───────────────────────────────────────────────────────────
    match /candidates/{userId} {
      allow read:  if isOwner(userId) || isAnyCompanyUser();
      allow write: if isOwner(userId);
    }

    // ── candidate_resumes ────────────────────────────────────────────────────
    match /candidate_resumes/{resumeId} {
      allow read: if isAuth() &&
        (resource == null || resource.data.candidate_id == request.auth.uid || isAnyCompanyUser());
      allow write: if isAuth() &&
        (resource == null || resource.data.candidate_id == request.auth.uid);
    }

    // ── job_offers ───────────────────────────────────────────────────────────
    match /job_offers/{jobId} {
      allow read:                    if true; // public
      allow create, update, delete:  if isAnyCompanyUser();
    }

    // ── tests ─────────────────────────────────────────────────────────────────
    match /tests/{testId} {
      allow read:                    if isAuth();
      allow create, update, delete:  if isAnyCompanyUser();
    }

    // ── applications ─────────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read:   if isAuth();
      allow create: if isAuth() &&
        request.resource.data.candidate_id == request.auth.uid;
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.candidate_id == request.auth.uid;
    }

    // ── mail (email notifications) ──────────────────────────────────────────
    match /mail/{mailId} {
      allow create: if isAnyCompanyUser();
    }

    // ── test_results ─────────────────────────────────────────────────────────
    match /test_results/{resultId} {
      allow read:   if isAuth();
      allow create: if isAuth();
    }
  }
}
