rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Resumes: solo el candidato dueño puede subir/leer/eliminar
    match /resumes/{candidateId}/{fileName} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == candidateId;
      allow delete: if request.auth != null && request.auth.uid == candidateId;
    }

    // Interview recordings
    match /interviews/{applicationId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Avatars de candidatos
    match /avatars/{userId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Logos de empresa
    match /logos/{companyId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
